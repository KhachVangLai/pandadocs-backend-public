# Reference only: Spring Boot does not automatically load .env files by itself.
# For local development, prefer copying:
#   src/main/resources/application-local.example.properties
# to:
#   src/main/resources/application-local.properties
# and run with the local profile.
#
# Database
DB_URL=jdbc:postgresql://localhost:5432/pandadocs
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=your_base64_or_long_random_jwt_secret
JWT_EXPIRATION_MS=86400000

# Firebase
# Option 1: local ignored JSON file path
FIREBASE_CREDENTIALS_PATH=secrets/firebase-service-account.json
# Option 2: base64-encoded service account JSON
FIREBASE_CREDENTIALS_BASE64=
# Option 3: leave both blank and use Application Default Credentials in cloud
FIREBASE_STORAGE_BUCKET=your-firebase-bucket.appspot.com

# PayOS
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_RETURN_URL=https://your-frontend.example.com/payment/success
PAYOS_CANCEL_URL=https://your-frontend.example.com/payment/cancel
PAYOS_WEBHOOK_URL=https://your-api.example.com/api/payments/payos-webhook

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-api.example.com/login/oauth2/code/google
OAUTH2_FRONTEND_REDIRECT_URL=https://your-frontend.example.com/oauth2/redirect

# CORS / Frontend
CORS_ALLOWED_ORIGINS=https://your-frontend.example.com,http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173

# Mail
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=2525
MAIL_USERNAME=apikey
MAIL_PASSWORD=your_mail_password
MAIL_FROM_EMAIL=no-reply@example.com

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Chat limits
CHAT_RATE_LIMIT_HOURLY=10
CHAT_RATE_LIMIT_DAILY=30
CHAT_SESSION_TIMEOUT=30
CHAT_MAX_MESSAGES=50
CHAT_AUTO_TITLE=true
